# made. Environment Variables — copy to .env and fill in real values
# NEVER commit .env to git

# --- Market Data ---
OANDA_API_KEY=your_oanda_api_key_here
OANDA_ACCOUNT_ID=your_oanda_account_id_here
OANDA_ENVIRONMENT=practice   # practice | live

TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# --- Economic Calendar ---
TRADING_ECONOMICS_API_KEY=your_trading_economics_key_here
JBLANKED_API_KEY=your_jblanked_key_here

# --- Broker Integration ---
META_API_TOKEN=your_metaapi_token_here
HFM_ACCOUNT_ID=your_hfm_account_id_here

# --- Database ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- Cache ---
REDIS_URL=redis://localhost:6379/0

# --- Notifications ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHANNEL_ID=@your_channel_id
APNS_KEY_ID=your_apns_key_id
APNS_TEAM_ID=your_apple_team_id
APNS_BUNDLE_ID=com.made.trading

# --- Engine ---
ENGINE_ENV=development   # development | production
LOG_LEVEL=INFO
SIGNAL_MIN_THRESHOLD=0.50
SHADOW_MODE=false        # true = generate signals but show to nobody
